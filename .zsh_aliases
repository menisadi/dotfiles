'

llmshell() {
  local cmd
  cmd=$(llm -m gemini-2.5-flash-lite \
    -s "Reply with the raw shell command only. No explanation, no commentary, no code fences, no backticks." \
    -x \
    "$@")
  echo "Generated Command:"
  echo "$cmd" | gum style --foreground 212 --padding "1 1" --italic

  local choice
  choice=$(gum choose "Run" "Copy" "Cancel")

  case $choice in
  "Run")
    eval "$cmd"
    ;;
  "Copy")
    echo "$cmd" | pbcopy
    echo "Command copied to clipboard."
    ;;
  "Cancel")
    echo "Operation canceled."
    ;;
  esac
}

llmsh() {
  local cmd
  cmd=$(llm -m gemini-2.5-flash \
    -s "Reply with the raw shell command only. No explanation, no commentary, no code fences, no backticks." \
    -x \
    "$@")
  echo "$ $cmd"
  print -n "[e]xecute  [y]ank  [q]uit: "
  read -rk 1 choice
  echo

  case $choice in
  e) echo && eval "$cmd" ;;
  y) echo "$cmd" | pbcopy && echo "Copied." ;;
  *) echo "Canceled." ;;
  esac
}

ask() { llm -t terse "$@"; }
alias ai=llmsh

jel() {
  local parent="$1"
  shift
  local mode="open"

  [[ "${1:-}" == "--all" ]] && mode="all"

  local status_flags=()
  [[ "$mode" == "open" ]] && status_flags=(--status "To Do" --status "In Progress")

  local selected
  selected=$(jira issue list -P "$parent" "${status_flags[@]}" \
    --csv --columns "KEY,SUMMARY,STATUS,ASSIGNEE" 2>&1 \
  | gum table -s ',')

  [[ -z "$selected" ]] && return 0

  local key
  key=$(echo "$selected" | cut -d',' -f1)
  jv "$key"
}

jv() {
  jira issue view "$@" --plain 2>&1 | awk '
    { gsub(/\033\[[0-9;]*m/, ""); sub(/[[:space:]]+$/, ""); sub(/^ +/, "") }
    /^-+.*Subtasks/ { if (line) print line; exit }
    /^$/ { if (line) { print line; line="" }; if (!blank) print; blank=1; next }
    { blank=0; line = (line ? line " " $0 : $0) }
    END { if (line) print line }
  '

  local subtasks
  subtasks=$(jira issue view "$@" --raw 2>&1 | jq -r '
    .fields.subtasks[] |
    "\(.key)  \(.fields.summary)  ‚ÄĘ  \(.fields.priority.name)  ‚ÄĘ  \(.fields.status.name)"
  ')
  [[ -n "$subtasks" ]] && printf "\nSubtasks\n%s\n" "$subtasks"
}
